# Copy to `.env` and fill in. The .env file is read by both
# scripts/deploy.sh (build/push) and `docker compose` (runtime).
# Never commit the populated .env.

# --- Build & push (scripts/deploy.sh) -------------------------------

# Where to push the image. Examples:
#   ghcr.io/youruser
#   docker.io/youruser
#   192.168.1.10:5000             (a local `registry:2` on your LAN)
REGISTRY=localhost:5000

# Image repository name under $REGISTRY. Default: kidspoints
IMAGE_NAME=kidspoints

# --- Runtime (docker compose on the deploy host) --------------------

# Required. Generate with:
#   python -c 'import secrets; print(secrets.token_urlsafe(50))'
DJANGO_SECRET_KEY=replace-me

# Comma-separated hostnames the app will accept. Include every name
# users might type, plus the LAN IP if relevant.
DJANGO_ALLOWED_HOSTS=points.lan,localhost

# Caddy site address. Use ":80" for HTTP-only on a LAN, or a real
# hostname (e.g. points.example.com) to get automatic HTTPS.
SITE_ADDRESS=:80

# Which image tag to deploy. Default :latest follows the most recent
# push; pin to a specific short SHA (e.g. a1b2c3d) to roll back.
IMAGE_TAG=latest

# Optional gunicorn tuning.
GUNICORN_WORKERS=3
